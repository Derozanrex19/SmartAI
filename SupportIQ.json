                      "parameters":  {
                                         "jsCode":  "const analysis = $items(\u0027Build AI Analysis + Policy\u0027, 0, 0)?.[0]?.json || {};\nconst emailResult = $json ?? null;\n\nconst asString = typeof emailResult === \u0027string\u0027\n  ? emailResult\n  : (typeof emailResult?.body === \u0027string\u0027 ? emailResult.body : \u0027\u0027);\n\nconst statusCodeRaw = Number(\n  emailResult?.statusCode ??\n  emailResult?.status ??\n  emailResult?.code ??\n  NaN\n);\nconst statusCode = Number.isFinite(statusCodeRaw) ? statusCodeRaw : null;\n\nconst explicitError =\n  emailResult?.error?.message ||\n  emailResult?.error ||\n  emailResult?.message ||\n  null;\n\nconst bodyLooksOk = asString.trim().toUpperCase() === \u0027OK\u0027;\nconst has2xx = statusCode !== null \u0026\u0026 statusCode \u003e= 200 \u0026\u0026 statusCode \u003c 300;\nconst explicitSuccess = emailResult?.ok === true || emailResult?.success === true;\nconst isSuccess = bodyLooksOk || has2xx || explicitSuccess;\n\nif (!isSuccess) {\n  const fallbackError =\n    explicitError ||\n    (statusCode !== null ? `Email send failed (${statusCode})` : null) ||\n    (asString ? `Email send failed (${asString.slice(0, 140)})` : null) ||\n    \u0027Email send failed: no success acknowledgment from EmailJS.\u0027;\n\n  return [\n    {\n      json: {\n        ...analysis,\n        route_action: \u0027needs_human\u0027,\n        status: \u0027needs_human\u0027,\n        auto_sent: false,\n        responded_at: null,\n        final_response: null,\n        email_error: fallbackError\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...analysis,\n      route_action: \u0027auto_send\u0027,\n      status: \u0027responded\u0027,\n      auto_sent: true,\n      responded_at: new Date().toISOString(),\n      final_response: analysis.draft_response || \u0027\u0027,\n      email_error: null\n    }\n  }\n];"
