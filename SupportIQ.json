                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const body = $('Webhook').first().json.body || {};\n\nconst validSentiments = new Set(['frustrated', 'neutral', 'happy']);\nconst validCategories = new Set(['technical', 'billing', 'feedback', 'other']);\nconst validPriorities = new Set(['low', 'medium', 'high']);\nconst fallbackDraft = 'Thank you for contacting SupportIQ. We received your ticket and a support agent will follow up shortly.';\n\nconst hasCandidate = Boolean($json?.choices?.[0]?.message?.content);\nlet upstreamError =\n  $json?.error?.message ||\n  $json?.message ||\n  (Array.isArray($json?.errors) && $json.errors[0]?.message) ||\n  null;\n\nlet raw = hasCandidate ? ($json.choices?.[0]?.message?.content ?? '{}') : '{}';\nif (typeof raw !== 'string') {\n  raw = JSON.stringify(raw ?? {});\n}\nraw = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/\\s*```$/i, '').trim();\n\nlet parseFailed = false;\nlet parsed = {};\n\nif (!upstreamError) {\n  try {\n    parsed = JSON.parse(raw || '{}');\n  } catch {\n    parseFailed = true;\n    parsed = {};\n  }\n} else {\n  parseFailed = true;\n}\n\nif (!upstreamError && !hasCandidate) {\n  upstreamError = 'Groq returned no choices content.';\n}\n\nif (!upstreamError && parseFailed) {\n  upstreamError = 'Invalid AI JSON output.';\n}\n\nconst sentiment = typeof parsed.sentiment === 'string' ? parsed.sentiment.toLowerCase().trim() : 'neutral';\nconst category = typeof parsed.category === 'string' ? parsed.category.toLowerCase().trim() : 'other';\nconst priority = typeof parsed.priority === 'string' ? parsed.priority.toLowerCase().trim() : 'medium';\n\nconst normalizedSentiment = validSentiments.has(sentiment) ? sentiment : 'neutral';\nconst normalizedCategory = validCategories.has(category) ? category : 'other';\nconst normalizedPriority = validPriorities.has(priority) ? priority : 'medium';\n\nconst confidenceRaw = Number(parsed.confidence);\nconst confidence = Number.isFinite(confidenceRaw)\n  ? Math.max(0, Math.min(100, Math.round(confidenceRaw)))\n  : 0;\nconst draft_response = typeof parsed.draft_response === 'string' && parsed.draft_response.trim()\n  ? parsed.draft_response.trim()\n  : fallbackDraft;\n\nconst needsHuman =\n  Boolean(upstreamError) ||\n  normalizedPriority === 'high' ||\n  confidence < 85 ||\n  normalizedCategory === 'billing';\n\nreturn [\n  {\n    json: {\n      ticket_id: body.ticketId || null,\n      first_name: body.firstName || '',\n      last_name: body.lastName || '',\n      email: body.email || '',\n      message: body.message || '',\n      sentiment: normalizedSentiment,\n      category: normalizedCategory,\n      priority: normalizedPriority,\n      confidence,\n      draft_response,\n      parse_failed: parseFailed,\n      route_action: needsHuman ? 'needs_human' : 'auto_send',\n      status: needsHuman ? 'needs_human' : 'ai_ready',\n      auto_sent: false,\n      responded_at: null,\n      final_response: null,\n      email_error: null,\n      ai_error: upstreamError,\n      raw_model_output: raw\n    }\n  }\n];"
