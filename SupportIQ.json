                  {
                      "parameters":  {
                                         "jsCode":  "const analysis = $items(\u0027Build AI Analysis + Policy\u0027, 0, 0)?.[0]?.json || {};\nconst emailResult = $json || {};\n\nconst errorMessage =\n  emailResult?.error?.message ||\n  emailResult?.message ||\n  (typeof emailResult === \u0027string\u0027 \u0026\u0026 emailResult.toLowerCase().includes(\u0027error\u0027) ? emailResult : null);\n\nconst statusCodeRaw = Number(emailResult?.statusCode ?? emailResult?.code ?? 200);\nconst statusCode = Number.isFinite(statusCodeRaw) ? statusCodeRaw : 200;\nconst hasFailure = Boolean(errorMessage) || statusCode \u003e= 400;\n\nif (hasFailure) {\n  return [\n    {\n      json: {\n        ...analysis,\n        route_action: \u0027needs_human\u0027,\n        status: \u0027needs_human\u0027,\n        auto_sent: false,\n        responded_at: null,\n        final_response: null,\n        email_error: errorMessage || `Email send failed (${statusCode})`\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...analysis,\n      route_action: \u0027auto_send\u0027,\n      status: \u0027responded\u0027,\n      auto_sent: true,\n      responded_at: new Date().toISOString(),\n      final_response: analysis.draft_response || \u0027\u0027,\n      email_error: null\n    }\n  }\n];\n"
                                     },
