                      "waitBetweenTries":  2000
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const body = $(\u0027Webhook\u0027).first().json.body || {};\n\nconst validSentiments = new Set([\u0027frustrated\u0027, \u0027neutral\u0027, \u0027happy\u0027]);\nconst validCategories = new Set([\u0027technical\u0027, \u0027billing\u0027, \u0027feedback\u0027, \u0027other\u0027]);\nconst validPriorities = new Set([\u0027low\u0027, \u0027medium\u0027, \u0027high\u0027]);\nconst fallbackDraft = \u0027Thank you for contacting SupportIQ. We received your ticket and a support agent will follow up shortly.\u0027;\n\nconst hasCandidate = Boolean($json?.candidates?.[0]?.content?.parts?.[0]?.text);\nlet upstreamError =\n  $json?.error?.message ||\n  $json?.message ||\n  (Array.isArray($json?.errors) \u0026\u0026 $json.errors[0]?.message) ||\n  null;\n\nlet raw = hasCandidate ? ($json.candidates?.[0]?.content?.parts?.[0]?.text ?? \u0027{}\u0027) : \u0027{}\u0027;\nif (typeof raw !== \u0027string\u0027) {\n  raw = JSON.stringify(raw ?? {});\n}\nraw = raw.replace(/^```json\\s*/i, \u0027\u0027).replace(/^```\\s*/i, \u0027\u0027).replace(/\\s*```$/i, \u0027\u0027).trim();\n\nlet parseFailed = false;\nlet parsed = {};\n\nif (!upstreamError) {\n  try {\n    parsed = JSON.parse(raw || \u0027{}\u0027);\n  } catch {\n    parseFailed = true;\n    parsed = {};\n  }\n} else {\n  parseFailed = true;\n}\n\nif (!upstreamError \u0026\u0026 !hasCandidate) {\n  upstreamError = \u0027Gemini returned no candidate content.\u0027;\n}\n\nif (!upstreamError \u0026\u0026 parseFailed) {\n  upstreamError = \u0027Invalid AI JSON output.\u0027;\n}\n\nconst sentiment = typeof parsed.sentiment === \u0027string\u0027 ? parsed.sentiment.toLowerCase().trim() : \u0027neutral\u0027;\nconst category = typeof parsed.category === \u0027string\u0027 ? parsed.category.toLowerCase().trim() : \u0027other\u0027;\nconst priority = typeof parsed.priority === \u0027string\u0027 ? parsed.priority.toLowerCase().trim() : \u0027medium\u0027;\n\nconst normalizedSentiment = validSentiments.has(sentiment) ? sentiment : \u0027neutral\u0027;\nconst normalizedCategory = validCategories.has(category) ? category : \u0027other\u0027;\nconst normalizedPriority = validPriorities.has(priority) ? priority : \u0027medium\u0027;\n\nconst confidenceRaw = Number(parsed.confidence);\nconst confidence = Number.isFinite(confidenceRaw)\n  ? Math.max(0, Math.min(100, Math.round(confidenceRaw)))\n  : 0;\nconst draft_response = typeof parsed.draft_response === \u0027string\u0027 \u0026\u0026 parsed.draft_response.trim()\n  ? parsed.draft_response.trim()\n  : fallbackDraft;\n\nconst needsHuman =\n  Boolean(upstreamError) ||\n  normalizedPriority === \u0027high\u0027 ||\n  confidence \u003c 85 ||\n  normalizedCategory === \u0027billing\u0027;\n\nreturn [\n  {\n    json: {\n      ticket_id: body.ticketId || null,\n      first_name: body.firstName || \u0027\u0027,\n      last_name: body.lastName || \u0027\u0027,\n      email: body.email || \u0027\u0027,\n      message: body.message || \u0027\u0027,\n      sentiment: normalizedSentiment,\n      category: normalizedCategory,\n      priority: normalizedPriority,\n      confidence,\n      draft_response,\n      parse_failed: parseFailed,\n      route_action: needsHuman ? \u0027needs_human\u0027 : \u0027auto_send\u0027,\n      status: needsHuman ? \u0027needs_human\u0027 : \u0027ai_ready\u0027,\n      auto_sent: false,\n      responded_at: null,\n      final_response: null,\n      email_error: null,\n      ai_error: upstreamError,\n      raw_model_output: raw\n    }\n  }\n];"
                                     },
