                                         "jsCode":  "const body = $(\u0027Webhook\u0027).first().json.body || {};\n\nconst validSentiments = new Set([\u0027frustrated\u0027, \u0027neutral\u0027, \u0027happy\u0027]);\nconst validCategories = new Set([\u0027technical\u0027, \u0027billing\u0027, \u0027feedback\u0027, \u0027other\u0027]);\nconst validPriorities = new Set([\u0027low\u0027, \u0027medium\u0027, \u0027high\u0027]);\nconst fallbackDraft = \u0027Thank you for contacting SupportIQ. We received your ticket and a support agent will follow up shortly.\u0027;\n\nconst asObject = (value) =\u003e {\n  if (!value) return null;\n  if (typeof value === \u0027object\u0027) return value;\n  if (typeof value === \u0027string\u0027) {\n    try { return JSON.parse(value); } catch { return null; }\n  }\n  return null;\n};\n\nconst candidates = [\n  asObject($json?.body),\n  asObject($json?.data),\n  asObject($json?.response),\n  asObject($json),\n].filter(Boolean);\n\nconst payload =\n  candidates.find((p) =\u003e p?.choices || p?.candidates || p?.error || p?.errors || p?.message) ||\n  candidates[0] ||\n  {};\n\nconst choiceContent = payload?.choices?.[0]?.message?.content;\nconst contentFromArray = Array.isArray(choiceContent)\n  ? choiceContent.map((part) =\u003e (typeof part?.text === \u0027string\u0027 ? part.text : \u0027\u0027)).filter(Boolean).join(\u0027\\n\u0027)\n  : null;\n\nconst aiText =\n  (typeof choiceContent === \u0027string\u0027 ? choiceContent : null) ||\n  contentFromArray ||\n  (typeof payload?.choices?.[0]?.text === \u0027string\u0027 ? payload.choices[0].text : null) ||\n  (typeof payload?.candidates?.[0]?.content?.parts?.[0]?.text === \u0027string\u0027 ? payload.candidates[0].content.parts[0].text : null) ||\n  \u0027\u0027;\n\nconst statusCodeRaw = Number(payload?.statusCode ?? payload?.status ?? $json?.statusCode ?? $json?.status ?? NaN);\nconst statusCode = Number.isFinite(statusCodeRaw) ? statusCodeRaw : null;\n\nlet upstreamError =\n  payload?.error?.message ||\n  payload?.error ||\n  payload?.message ||\n  (Array.isArray(payload?.errors) \u0026\u0026 (payload.errors[0]?.message || payload.errors[0])) ||\n  $json?.error?.message ||\n  $json?.error ||\n  $json?.message ||\n  (Array.isArray($json?.errors) \u0026\u0026 ($json.errors[0]?.message || $json.errors[0])) ||\n  null;\n\nif (!upstreamError \u0026\u0026 statusCode !== null \u0026\u0026 statusCode \u003e= 400) {\n  upstreamError = `AI request failed with status ${statusCode}.`;\n}\n\nlet raw = typeof aiText === \u0027string\u0027 ? aiText : JSON.stringify(aiText ?? {});\nraw = raw.replace(/^```json\\s*/i, \u0027\u0027).replace(/^```\\s*/i, \u0027\u0027).replace(/\\s*```$/i, \u0027\u0027).trim();\n\nlet parsed = null;\nif (!upstreamError \u0026\u0026 raw) {\n  try { parsed = JSON.parse(raw); } catch { parsed = null; }\n}\n\nconst normalizeEnum = (value, allowed, fallback) =\u003e {\n  const v = typeof value === \u0027string\u0027 ? value.toLowerCase().trim() : \u0027\u0027;\n  return allowed.has(v) ? v : fallback;\n};\n\nconst text = String(body.message || \u0027\u0027).trim();\nconst textLc = text.toLowerCase();\n\nconst inferCategory = () =\u003e {\n  if (/(charge|refund|invoice|payment|billing|subscription|credit card|price)/.test(textLc)) return \u0027billing\u0027;\n  if (/(bug|error|crash|login|not working|unable|fail|issue|technical|down|outage)/.test(textLc)) return \u0027technical\u0027;\n  if (/(suggest|feedback|feature|idea|love|great|enjoy|thanks|appreciate)/.test(textLc)) return \u0027feedback\u0027;\n  return \u0027other\u0027;\n};\n\nconst inferSentiment = () =\u003e {\n  if (/(angry|frustrat|urgent|terrible|hate|worst|blocked|can\u0027t|cannot|not working)/.test(textLc)) return \u0027frustrated\u0027;\n  if (/(great|love|awesome|thanks|appreciate|happy|enjoy)/.test(textLc)) return \u0027happy\u0027;\n  return \u0027neutral\u0027;\n};\n\nconst inferPriority = (category, sentiment) =\u003e {\n  if (/(urgent|asap|immediately|critical|down|outage|blocked|cannot|can\u0027t)/.test(textLc)) return \u0027high\u0027;\n  if (category === \u0027billing\u0027) return \u0027medium\u0027;\n  if (category === \u0027feedback\u0027 || sentiment === \u0027happy\u0027) return \u0027low\u0027;\n  return \u0027medium\u0027;\n};\n\nconst makeDraft = (category, sentiment) =\u003e {\n  const firstName = String(body.firstName || \u0027there\u0027).trim() || \u0027there\u0027;\n  if (category === \u0027feedback\u0027) {\n    return `Thank you for your feedback, ${firstName}. We appreciate your suggestion and have shared it with our product team. We are actively reviewing opportunities to improve performance and usability. If you have more ideas, please reply to this email and we will include them in our review.`;\n  }\n  if (category === \u0027billing\u0027) {\n    return `Thanks for contacting SupportIQ, ${firstName}. We received your billing concern and routed it to a support specialist for review. Please share any invoice IDs or charge timestamps so we can investigate and follow up accurately.`;\n  }\n  if (category === \u0027technical\u0027) {\n    return `Thanks for reporting this, ${firstName}. We understand the issue is affecting your workflow and our team is investigating. Please share any error text, screenshots, and the time it occurred so we can isolate the root cause and provide the next action.`;\n  }\n  return sentiment === \u0027happy\u0027\n    ? `Thanks for reaching out, ${firstName}. We appreciate your message and are glad to hear your experience. If you want to share additional details or suggestions, we are happy to pass them to the team.`\n    : fallbackDraft;\n};\n\nconst fallbackCategory = inferCategory();\nconst fallbackSentiment = inferSentiment();\nconst fallbackPriority = inferPriority(fallbackCategory, fallbackSentiment);\n\nconst sentiment = normalizeEnum(parsed?.sentiment, validSentiments, fallbackSentiment);\nconst category = normalizeEnum(parsed?.category, validCategories, fallbackCategory);\nconst priority = normalizeEnum(parsed?.priority, validPriorities, fallbackPriority);\n\nconst confidenceRaw = Number(parsed?.confidence);\nconst confidence = Number.isFinite(confidenceRaw)\n  ? Math.max(0, Math.min(100, Math.round(confidenceRaw)))\n  : (upstreamError ? 0 : 78);\n\nconst draft_response =\n  typeof parsed?.draft_response === \u0027string\u0027 \u0026\u0026 parsed.draft_response.trim()\n    ? parsed.draft_response.trim()\n    : makeDraft(category, sentiment);\n\nconst hardFailure = Boolean(upstreamError);\n\nconst needsHuman =\n  hardFailure ||\n  priority === \u0027high\u0027 ||\n  confidence \u003c 85 ||\n  category === \u0027billing\u0027;\n\nreturn [\n  {\n    json: {\n      ticket_id: body.ticketId || null,\n      first_name: body.firstName || \u0027\u0027,\n      last_name: body.lastName || \u0027\u0027,\n      email: body.email || \u0027\u0027,\n      message: body.message || \u0027\u0027,\n      sentiment,\n      category,\n      priority,\n      confidence,\n      draft_response,\n      parse_failed: !parsed,\n      route_action: needsHuman ? \u0027needs_human\u0027 : \u0027auto_send\u0027,\n      status: needsHuman ? \u0027needs_human\u0027 : \u0027ai_ready\u0027,\n      auto_sent: false,\n      responded_at: null,\n      final_response: null,\n      email_error: null,\n      ai_error: hardFailure ? String(upstreamError) : null,\n      raw_model_output: raw || \u0027{}\u0027\n    }\n  }\n];"
